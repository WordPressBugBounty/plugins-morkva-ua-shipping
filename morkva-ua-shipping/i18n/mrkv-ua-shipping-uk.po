msgid ""
"The following words are not allowed in the name of the shipment in English:\n"
"                BRYUKI, ACCESSEROISE, ACCESSORIES, GIFT, GIFT BOX, GIFTS, "
"HANDMADE GIFT, KOSTYUM, KURTKA,\n"
"                ODEZHDA, PODAROK, PRESENT, PREZENT, SHAPKA, SOLDATYKY, "
"SOUVENIR, SOUVENIR SET, SOUVENIRS,\n"
"                SUVENIER, SUVENIR, TAINA, XYDI, Other, item, cadeau, or only "
"numbers (for example, 963258).\n"
"                The length should not exceed 32 characters."
msgstr ""
"Наступні слова заборонені до використання:\n"
"                BRYUKI, ACCESSEROISE, ACCESSORIES, GIFT, GIFT BOX, GIFTS, "
"HANDMADE GIFT, KOSTYUM, KURTKA,\n"
"                ODEZHDA, PODAROK, PRESENT, PREZENT, SHAPKA, SOLDATYKY, "
"SOUVENIR, SOUVENIR SET, SOUVENIRS,\n"
"                SUVENIER, SUVENIR, TAINA, XYDI, Other, item, cadeau, або "
